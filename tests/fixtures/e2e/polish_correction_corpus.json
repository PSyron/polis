      "description": "Brak spacji po przecinku.",
      "tags": ["punctuation", "spacing"]
    },
    {
      "id": "name_case_forms_reference",
      "input": "Agnieszka i Anię zaprosiłam do domu.",
      "expected_output": "Agnieszka i Anię zaprosiłam do domu.",
