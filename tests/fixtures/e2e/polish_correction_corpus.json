      "tags": ["spelling", "orthography", "name"]
    },
    {
      "id": "agreement_ty_imie",
      "input": "Ania, ty jestem gotowa.",
      "expected_output": "Ania, ty jesteś gotowa.",
      "description": "Zgoda podmiotu i orzeczenia z nazwą + zaimkiem.",
      "tags": ["agreement", "name", "person_inflection"]
    },
    {
      "id": "agreement_oni_plural",
      "input": "Oni jest gotowi.",
      "expected_output": "Oni są gotowi.",
      "description": "Liczba podmiotu z orzeczeniem.",
      "tags": ["agreement", "number"]
    },
    {
      "id": "syntax_list_spacing",
      "input": "1.Punkt pierwszy.",
